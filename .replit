modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[objectStorage]
defaultBucketID = "replit-objstore-6751d8fb-0a63-427b-867d-c26722039490"

[userenv]

[userenv.shared]
EXPO_PUBLIC_API_BASE_URL = "https://db2a4672-658d-4b41-a6fd-aca8428cf013-00-jlaipag1e5pw.janeway.replit.dev"

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 18115
externalPort = 3000

[nix]
channel = "stable-25_05"
packages = ["freetype", "gumbo", "harfbuzz", "jbig2dec", "libjpeg_turbo", "mupdf", "openjpeg", "swig", "xcbuild"]
